# dependencies (Render installs these from package.json)
node_modules/

# secrets — NEVER commit these; set them in Render's environment variables instead
.env
.env.local

# runtime data (the app auto-creates this; keep it out of the repo)
data.json
data-*.json

# uploaded photos (created at runtime)
uploads/

# logs / OS cruft
*.log
.DS_Store
Thumbs.db
