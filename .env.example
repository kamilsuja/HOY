# Copy to .env (or set in your host's dashboard). Keys stay server-side.

# --- Server ---
PORT=3000
NODE_ENV=development          # "production" stops returning login codes in responses

# --- Security (set these in production) ---
AUTH_SECRET=                  # long random string; keys the OTP HMAC + must be stable
ALLOWED_ORIGIN=               # comma-separated origins allowed via CORS, e.g.
                              #   https://app.hoy.so,https://hoy.so
                              # empty = dev mode: only localhost is allowed

# --- Data store ---
# Leave DATABASE_URL empty to use the zero-dep JSON file (dev/MVP).
# Set it to use Postgres (run schema.sql first, then `npm install pg`).
DATABASE_URL=
# DATA_FILE=./data.json       # where the JSON store lives (json mode only)

# --- Email (Resend) ---
RESEND_API_KEY=
RESEND_FROM=Hoy <bookings@yourdomain.so>

# --- SMS (Twilio) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# Links used inside emails
APP_URL=https://hoy.app

# --- Photo storage (uploads) ---
# Leave empty for dev: uploads are written to public/uploads and served locally.
# Set these for production: presigned direct-to-storage uploads (S3/R2/B2/MinIO).
S3_BUCKET=
S3_REGION=auto
S3_KEY=
S3_SECRET=
S3_ENDPOINT=            # e.g. https://<acct>.r2.cloudflarestorage.com (omit for AWS S3)
S3_PUBLIC_BASE=         # e.g. https://cdn.hoy.so (public/CDN base for stored files)

# --- ID verification ---
# Leave empty for dev: /verify/start returns a mock URL; complete via /verify/dev-complete.
# Set these for production (Stripe Identity / Persona / Onfido / Veriff).
IDENTITY_API_KEY=
IDENTITY_API_URL=       # vendor "create verification session" endpoint
IDENTITY_WEBHOOK_SECRET=  # shared secret to verify /webhooks/identity callbacks

# Optional: Somali SMS gateway (Africa's Talking) if you swap sendSMS
# AT_API_KEY=
# AT_USERNAME=
# AT_FROM=

# Comma-separated emails that get admin/operator access (empty in dev = any logged-in user is admin)
ADMIN_EMAILS=

# --- Card payments (Stripe Checkout) ---
# Get keys at https://dashboard.stripe.com/apikeys (use sk_test_... to start).
# Card payments stay OFF until STRIPE_SECRET_KEY is set, so the app runs fine without it.
STRIPE_SECRET_KEY=             # sk_test_... (test) or sk_live_... (real money)
STRIPE_WEBHOOK_SECRET=         # whsec_... from your /webhooks/stripe endpoint in the Stripe dashboard
# APP_URL is reused for the success/cancel return links after payment.
